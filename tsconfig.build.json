{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "src/**/*",
    "index.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/__tests__/**"
  ]
}
